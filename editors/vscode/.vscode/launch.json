{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run solsp Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--disable-extensions"
      ],
      "env": {
        "SOLSP_SERVER_PATH": "${workspaceFolder}/../../target/debug/solsp-server"
      },
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "compile"
    }
  ]
}

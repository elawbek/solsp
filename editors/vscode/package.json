{
  "name": "solsp-vscode",
  "displayName": "solsp — Solidity Language Server",
  "description": "Thin VS Code client for the solsp Solidity language server (outline, diagnostics, semantic highlighting).",
  "version": "0.0.1",
  "publisher": "solsp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elawbek/solsp.git",
    "directory": "editors/vscode"
  },
  "homepage": "https://github.com/elawbek/solsp#readme",
  "bugs": {
    "url": "https://github.com/elawbek/solsp/issues"
  },
  "qna": "https://github.com/elawbek/solsp/issues",
  "keywords": [
    "solidity",
    "ethereum",
    "smart-contracts",
    "language-server",
    "lsp"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:solidity"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "solidity",
        "aliases": [
          "Solidity",
          "solidity"
        ],
        "extensions": [
          ".sol"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "solsp",
      "properties": {
        "solsp.server.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the `solsp-server` binary. If empty, the extension looks for a Cargo build under the workspace's `target/debug` then `target/release`, and finally falls back to `solsp-server` on `PATH`."
        },
        "solsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace the JSON-RPC traffic between VS Code and solsp-server (for debugging)."
        }
      }
    },
    "configurationDefaults": {
      "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
          "decorator:solidity": "#cd5c5c"
        }
      }
    },
    "grammars": [
      {
        "language": "solidity",
        "scopeName": "source.solidity",
        "path": "./syntaxes/solidity.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run typecheck && npm run bundle",
    "typecheck": "tsc -p ./ --noEmit",
    "bundle": "esbuild ./src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=out/extension.js",
    "package:platform": "node ./scripts/package-platform.mjs",
    "watch": "esbuild ./src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=out/extension.js --watch"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.4.0"
  }
}
